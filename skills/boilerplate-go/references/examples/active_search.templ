package pages

import (
	"github.com/go-chi/chi/v5"
	"github.com/go-faker/faker/v4"
	"github.com/starfederation/datastar-go/datastar"
	"net/http"
	"slices"
	"strings"
)

type ActiveSearchUser struct {
	ID        string `json:"id"`
	FirstName string `json:"firstName"`
	LastName  string `json:"lastName"`
}

var activeSearchUsers = func() []*ActiveSearchUser {
	users := make([]*ActiveSearchUser, 100)
	for i := range users {
		users[i] = &ActiveSearchUser{
			ID:        faker.UUIDHyphenated(),
			FirstName: faker.FirstName(),
			LastName:  faker.LastName(),
		}
	}
	return users
}()

func SetupActiveSearch(router chi.Router) {
	router.Get("/active-search", func(w http.ResponseWriter, r *http.Request) {
		ActiveSearchPage(activeSearchUsers[:10]).Render(r.Context(), w)
	})

	router.Get("/active-search/search", func(w http.ResponseWriter, r *http.Request) {
		type signals struct {
			Search string `json:"search"`
		}
		s := &signals{}
		if err := datastar.ReadSignals(r, s); err != nil {
			http.Error(w, err.Error(), http.StatusBadRequest)
			return
		}

		query := strings.ToLower(s.Search)
		filtered := []*ActiveSearchUser{}
		for _, u := range activeSearchUsers {
			if strings.Contains(strings.ToLower(u.FirstName), query) ||
				strings.Contains(strings.ToLower(u.LastName), query) {
				filtered = append(filtered, u)
			}
		}

		slices.SortFunc(filtered, func(a, b *ActiveSearchUser) int {
			return strings.Compare(a.FirstName, b.FirstName)
		})

		if len(filtered) > 10 {
			filtered = filtered[:10]
		}

		datastar.NewSSE(w, r).PatchElementTempl(ActiveSearchResults(filtered))
	})
}

templ ActiveSearchPage(users []*ActiveSearchUser) {
	@Base("Active Search") {
		<div class="container mx-auto p-8">
			<h1 class="text-2xl font-bold mb-4">Active Search</h1>
			<p class="mb-4 text-gray-600">
				Search as you type with debouncing (200ms).
			</p>
			@activeSearchComponent(users)
		</div>
	}
}

templ activeSearchComponent(users []*ActiveSearchUser) {
	<div id="search-demo">
		<input
			type="text"
			class="input input-bordered w-full mb-4"
			placeholder="Search contacts..."
			data-bind:search
			data-on:input__debounce.200ms="@get('/active-search/search')"
		/>
		@ActiveSearchResults(users)
	</div>
}

templ ActiveSearchResults(users []*ActiveSearchUser) {
	<table class="table w-full" id="results">
		<thead>
			<tr>
				<th>First Name</th>
				<th>Last Name</th>
			</tr>
		</thead>
		<tbody>
			if len(users) == 0 {
				<tr><td colspan="2" class="text-center text-gray-500">No results found</td></tr>
			}
			for _, u := range users {
				<tr>
					<td>{ u.FirstName }</td>
					<td>{ u.LastName }</td>
				</tr>
			}
		</tbody>
	</table>
}