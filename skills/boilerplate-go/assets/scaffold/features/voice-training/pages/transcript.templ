package pages

templ TranscriptBubble(speaker, text string, isUser bool, isTurnComplete bool, messageID string) {
	<div class={ templ.Classes("flex w-full", templ.KV("justify-end", isUser), templ.KV("justify-start", !isUser)) }
		 id={ messageID }>
		<div class={ templ.Classes("max-w-[80%] rounded-2xl px-4 py-3", templ.KV("bg-primary text-primary-content", isUser), templ.KV("bg-base-300", !isUser), templ.KV("streaming", !isTurnComplete)) }>
			<div class={ templ.Classes("text-xs font-medium mb-1", templ.KV("text-primary-content/70", isUser), templ.KV("text-base-content/60", !isUser)) }>
				if isUser {
					Você
				} else {
					{ speaker }
				}
			</div>
			<div class="text-sm message-text whitespace-pre-wrap">{ text }</div>
		</div>
		<script>
			(function() {
				const container = document.getElementById('chat-container');
				if (container) {
					container.scrollTop = container.scrollHeight;
				}
			})();
		</script>
	</div>
}

templ SystemMessage(text string) {
	<div class="flex justify-center w-full">
		<div class="bg-base-200 text-base-content/60 text-xs px-3 py-1 rounded-full">
			{ text }
		</div>
	</div>
}
