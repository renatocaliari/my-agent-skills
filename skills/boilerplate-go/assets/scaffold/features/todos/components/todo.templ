package components 

import (
	"fmt"
	"github.com/starfederation/datastar-go/datastar"
	common "northstar/features/common/components"
)

type TodoViewMode int

const (
	TodoViewModeAll TodoViewMode = iota
	TodoViewModeActive
	TodoViewModeCompleted
	TodoViewModeLast
)

var TodoViewModeStrings = []string{"All", "Active", "Completed"}

type Todo struct {
	Text      string `json:"text"`
	Completed bool   `json:"completed"`
}

type TodoMVC struct {
	Todos      []*Todo      `json:"todos"`
	EditingIdx int          `json:"editingIdx"`
	Mode       TodoViewMode `json:"mode"`
}

templ TodosMVCView(mvc *TodoMVC) {
	{{
		hasTodos := len(mvc.Todos) > 0
		left, completed := 0, 0
		for _, todo := range mvc.Todos {
			if !todo.Completed {
				left++
			} else {
				completed++
			}
		}
		input := ""
		if mvc.EditingIdx >= 0 {
			input = mvc.Todos[mvc.EditingIdx].Text
		}
	}}
	<div
		id="todos-container"
		class="h-full relative border border-solid border-primary rounded p-4 my-4 max-w-4xl mx-auto"
		data-signals={ fmt.Sprintf("{input:'%s'}", input) }
	>
		<section class="flex flex-col gap-4">
			<header class="flex flex-col gap-4">
				<div role="alert" class="alert alert-info">
						@common.Icon("material-symbols:info")
						<div class="flex flex-col gap-1">
							<span>
								This mini application is driven by a
								<span class="italic font-bold uppercase">single get request!</span>
							</span>
							<span class="text-xs opacity-80">
								As you interact with the UI, the backend state is updated and new partial HTML fragments are sent down to the client via Server-Sent Events. Open your dev tools and watch the network tab to see the magic happen.
							</span>
						</div>
					</div>
					<div class="text-center py-4">
						<h1 class="text-5xl font-bold uppercase font-brand md:text-7xl text-primary mb-2">todo</h1>
						<p class="text-base-content/70 max-w-lg mx-auto mb-2">
							Go boilerplate inspired by <a class="link link-primary font-semibold" href="https://github.com/delaneyj/toolbelt" target="_blank">Northstar</a> (Boilerplate for creating real-time Hypermedia applications with <a class="link link-primary" href="https://data-star.dev/" target="_blank">Datastar</a> and <a class="link link-primary" href="https://nats.io/" target="_blank">NATS</a>), featuring <a class="link link-primary" href="http://fabricjs.com" target="_blank">Fabric.js</a> Whiteboard and Real-time Voice (<a class="link link-primary" href="https://livekit.io" target="_blank">LiveKit</a> + <a class="link link-primary" href="https://ai.google.dev" target="_blank">Gemini</a>).
						</p>
					</div>
					<div class="flex items-center gap-2">
						if hasTodos {
							<div class="tooltip" data-tip="toggle all todos">
								<button
									id="toggleAll"
									class="btn btn-lg"
									data-on:click={ datastar.PostSSE("/api/todos/-1/toggle") }
									data-indicator="toggleAllFetching"
									data-attr-disabled="$toggleAllFetching"
								>
									@common.Icon("material-symbols:checklist")
								</button>
							</div>
						}
						if mvc.EditingIdx <0 {
							@TodoInput(-1)
						}
						@common.SseIndicator("toggleAllFetching")
					</div>
				</header>
				if hasTodos {
					<section class="max-h-[calc(100vh-400px)] overflow-scroll">
						<ul class="divide-y divide-primary">
							for i, todo := range mvc.Todos {
								@TodoRow(mvc.Mode, todo, i, i == mvc.EditingIdx)
							}
						</ul>
					</section>
					<footer class="flex flex-wrap items-center justify-between gap-2">
						<span class="todo-count">
							<strong>
								{ fmt.Sprint(left) }
								if (len(mvc.Todos) > 1) {
									items
								} else {
									item
								}
							</strong> left
						</span>
						<div class="join">
							for i := TodoViewModeAll; i < TodoViewModeLast; i++ {
								if i == mvc.Mode {
									<div class="btn btn-xs btn-primary join-item">{ TodoViewModeStrings[i] }</div>
								} else {
									<button
										class="btn btn-xs join-item"
										data-on:click={ datastar.PutSSE("/api/todos/mode/%d", i) }
									>
										{ TodoViewModeStrings[i] }
									</button>
								}
							}
						</div>
						<div class="join">
							if completed > 0 {
								<div class="tooltip" data-tip={ fmt.Sprintf("clear %d completed todos", completed) }>
									<button
										class="btn btn-error btn-xs join-item"
										data-on:click={ datastar.DeleteSSE("/api/todos/-1") }
									>
										@common.Icon("material-symbols:delete")
									</button>
								</div>
							}
							<div class="tooltip" data-tip="Reset list">
								<button
									class="btn btn-warning btn-xs join-item"
									data-on:click={ datastar.PutSSE("/api/todos/reset") }
								>
									@common.Icon("material-symbols:delete-sweep")
								</button>
							</div>
						</div>
					</footer>
					<footer class="flex justify-center text-xs">
						<div>Click to edit, click away to cancel, press enter to save.</div>
					</footer>
				}
			</section>
	</div>
}

templ TodoInput(i int) {
	<input
		id="todoInput"
		data-testid="todos_input"
		class="flex-1 w-full italic input input-bordered input-lg"
		placeholder="What needs to be done?"
		data-bind="input"
		data-on:keydown={ fmt.Sprintf(`
			if (evt.key !== 'Enter' || !$input.trim().length) return;
			%s;
			$input = '';
		`, datastar.PutSSE("/api/todos/%d/edit",i) ) }
		if i >= 0 {
			data-on:click__outside={ datastar.PutSSE("/api/todos/cancel") }
		}
	/>
}

templ TodoRow(mode TodoViewMode, todo *Todo, i int, isEditing bool) {
	{{
		indicatorID := fmt.Sprintf("indicator%d", i)
		fetchingSignalName := fmt.Sprintf("fetching%d", i)
	}}
	if isEditing {
		@TodoInput(i)
	} else if (
		mode == TodoViewModeAll) ||
		(mode == TodoViewModeActive && !todo.Completed) ||
		(mode == TodoViewModeCompleted && todo.Completed) {
		<li class="flex items-center gap-4 p-2 group" id={ fmt.Sprintf("todo%d", i) }>
			<input
				type="checkbox"
				class="checkbox checkbox-lg checkbox-primary"
				if todo.Completed {
					checked
				}
				data-on:click={ datastar.PostSSE("/api/todos/%d/toggle", i) }
				data-indicator={ fetchingSignalName }
			/>
			<label
				id={ indicatorID }
				class={ 
					"flex-1 text-lg cursor-pointer select-none",
					templ.KV("line-through opacity-60", todo.Completed),
				}
				data-on:click={ datastar.GetSSE("/api/todos/%d/edit", i) }
				data-indicator={ fetchingSignalName }
			>
				{ todo.Text }
			</label>
			@common.SseIndicator(fetchingSignalName)
			<button
				id={ fmt.Sprintf("delete%d", i) }
				class="invisible btn btn-error btn-sm group-hover:visible"
				data-on:click={ datastar.DeleteSSE("/api/todos/%d", i) }
				data-testid={ fmt.Sprintf("delete_todo%d", i) }
				data-indicator={ fetchingSignalName }
				data-attr-disabled={ fetchingSignalName + "" }
			>
				@common.Icon("material-symbols:close")
			</button>
		</li>
	}
}
